# ========================================
# .ENV_EXAMPLE - Ejemplo de Variables de Entorno
# ----------------------------------------
# Copia este archivo como .env y edita los valores.
# ========================================


# --- CONFIGURACIÓN DE APLICACIÓN ---
APP_NAME="Scoundrel Game"
APP_ENV=local
APP_KEY=base64:[REGENERATE_ME] 
APP_DEBUG=true
APP_URL=http://api.localhost
FRONTEND_URL=http://localhost:5174


# --- CONFIGURACIÓN DE LOGS ---
LOG_CHANNEL=stack
LOG_LEVEL=debug


# --- BASE DE DATOS (DOCKER) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=scoundrel
DB_USERNAME=master
DB_PASSWORD=ofpuppets 


# --- SESIONES Y SEGURIDAD (CRÍTICO PARA HTTPS) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax


# --- CACHE Y COLAS ---
CACHE_STORE=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database


# --- GOOGLE AUTH ---
GOOGLE_CLIENTE_ID=[YOUR_GOOGLE_CLIENT_ID]
GOOGLE_CLIENTE_SECRET=[YOUR_GOOGLE_CLIENT_SECRET]
GOOGLE_REDIRECT_URI=http://api.localhost/api/auth/google/callback 


# --- X / TWITTER AUTH ---
TWITTER_CLIENT_ID=[YOUR_TWITTER_CLIENT_ID]
TWITTER_CLIENT_SECRET=[YOUR_TWITTER_CLIENT_SECRET]
TWITTER_REDIRECT_URI=http://api.localhost/api/auth/x/callback 


# --- BROADCASTING (WebSockets) ---
BROADCAST_CONNECTION=log
